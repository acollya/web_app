# ── Core ──────────────────────────────────────────────────────────────────────
STAGE=dev
LOG_LEVEL=DEBUG
AWS_REGION=sa-east-1
AWS_ACCOUNT_ID=123456789012

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: run `docker-compose up` to start postgres with pgvector
DB_HOST=localhost
DB_PORT=5432
DB_NAME=acollya
DB_USER=acollya_admin
DB_PASSWORD=localdev

# In Lambda, DB_SECRET_ARN is set via CDK — credentials fetched from Secrets Manager
# DB_SECRET_ARN=arn:aws:secretsmanager:sa-east-1:...

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TLS=false
# REDIS_PASSWORD=  # not needed for local dev

# ── Storage ───────────────────────────────────────────────────────────────────
MEDIA_BUCKET=acollya-media-local

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate with:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed Google Client IDs (Web + iOS + Android)
# Get them at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_IDS=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com,YOUR_IOS_CLIENT_ID.apps.googleusercontent.com,YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com

# ── App Config ────────────────────────────────────────────────────────────────
TRIAL_DAYS=14
FREE_CHAT_MESSAGES_PER_DAY=20
PREMIUM_CHAT_MESSAGES_PER_DAY=9999
